# ═══════════════════════════════════════════════════════════════
#  PagerMonitor — Server Configuration
#  Copy to .env and edit before first run
# ═══════════════════════════════════════════════════════════════

# ── Deployment mode ───────────────────────────────────────────
# Option 1 (RPi all-in-one): DISABLE_SDR=false
# Option 2 (Proxmox server, RPi sends messages): DISABLE_SDR=true
DISABLE_SDR=false

# ── Network ──────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Database ─────────────────────────────────────────────────
DB_PATH=./data/pagermonitor.db

# ── Logging ──────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
#  RTL-SDR settings (Option 1 only — ignored when DISABLE_SDR=true)
# ═══════════════════════════════════════════════════════════════

# Frequency — required. Use M suffix: 173.250M
# Multiple frequencies (hop scan): 173.250M:152.240M:462.950M
RTL_FM_FREQ=173.250M

# Modulation: fm | am | usb | lsb | wbfm | raw
RTL_FM_MODULATION=fm

# Sample rate Hz (22050 recommended for POCSAG)
RTL_FM_SAMPLE_RATE=22050

# Gain dB. 0 = auto AGC. Try 40 for POCSAG.
RTL_FM_GAIN=40

# Device index (0 = first dongle, 1 = second, etc.)
RTL_FM_DEVICE_INDEX=0

# PPM frequency correction. Find with: rtl_test -p
RTL_FM_PPM=0

# Squelch level. 0 = disabled (recommended for POCSAG)
RTL_FM_SQUELCH=0

# ── Advanced RTL-SDR (leave empty for defaults) ───────────────
RTL_FM_RESAMPLE_RATE=
RTL_FM_LOWPASS=
RTL_FM_TUNER_BANDWIDTH=
RTL_FM_DIRECT_SAMPLING=
RTL_FM_OFFSET_TUNING=0

# ═══════════════════════════════════════════════════════════════
#  multimon-ng settings (Option 1 only)
# ═══════════════════════════════════════════════════════════════

# Protocols (space-separated)
# Options: POCSAG512 POCSAG1200 POCSAG2400 FLEX EAS DTMF
MULTIMON_PROTOCOLS=POCSAG1200

# Suppress startup banner (recommended)
MULTIMON_QUIET=1

# Input format — always raw when piping from rtl_fm
MULTIMON_INPUT_FORMAT=raw

# POCSAG charset (-C flag). Possible values: US (default), FR, DE, SE, DK, SI
MULTIMON_POCSAG_CHARSET=

# Decode numeric as special characters (0=off 1=on)
MULTIMON_POCSAG_SPECIAL=0

# Verbosity (leave empty for default)
MULTIMON_VERBOSITY=

# ═══════════════════════════════════════════════════════════════
#  Notification services (configure via Admin panel instead)
# ═══════════════════════════════════════════════════════════════
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GOTIFY_URL=
GOTIFY_TOKEN=
GOTIFY_PRIORITY=5

# ── MQTT (Home Assistant) ─────────────────────────────────────
MQTT_BROKER=
MQTT_TOPIC=pagermonitor/messages
