# ═══════════════════════════════════════════════════════════════
#  PagerMonitor Client — Raspberry Pi Configuration
#  This file is used ONLY on the RPi (Option 2 / distributed mode)
#  Copy to .env and edit before first run
# ═══════════════════════════════════════════════════════════════

# ── Server connection ─────────────────────────────────────────
# URL of your PagerMonitor server (Proxmox VM / PC)
# Use http:// for local network, https:// if you have nginx+SSL
SERVER_URL=http://192.168.1.100:3000

# Shared secret key — must match exactly what is set in
# Admin → SDR Client on the server web interface
# Generate a key there, copy it here.
CLIENT_KEY=paste-your-key-from-admin-panel-here

# Unique name for this Pi (shown in server logs)
# If you have multiple RPis, use rpi-1, rpi-2, etc.
CLIENT_ID=rpi-1

# ═══════════════════════════════════════════════════════════════
#  RTL-SDR settings
# ═══════════════════════════════════════════════════════════════

# Frequency — required. Use M suffix.
RTL_FM_FREQ=173.250M

# Gain dB. 0 = auto AGC. Try 40 for POCSAG.
RTL_FM_GAIN=40

# Device index (0 = first dongle)
RTL_FM_DEVICE_INDEX=0

# PPM frequency correction. Find with: rtl_test -p
RTL_FM_PPM=0

# Squelch. 0 = disabled (recommended)
RTL_FM_SQUELCH=0

# ─ Advanced (leave empty for defaults) ────────────────────────
RTL_FM_MODULATION=fm
RTL_FM_SAMPLE_RATE=22050
RTL_FM_RESAMPLE_RATE=
RTL_FM_OFFSET_TUNING=0

# ═══════════════════════════════════════════════════════════════
#  multimon-ng settings
# ═══════════════════════════════════════════════════════════════

# Protocols (space-separated)
MULTIMON_PROTOCOLS=POCSAG1200

# Suppress startup banner
MULTIMON_QUIET=1

# POCSAG charset for non-ASCII characters
# For Slovenian Š Č Ž: ISO-8859-2
MULTIMON_POCSAG_CHARSET=

# Decode numeric as special characters (0=off 1=on)
MULTIMON_POCSAG_SPECIAL=0

# ═══════════════════════════════════════════════════════════════
#  Multiple SDR dongles (optional)
#  If you have 2+ dongles, use DONGLES instead of the settings above.
#  DONGLES is a JSON array — one object per dongle.
#  Each object can override any of the global settings above.
#
#  Example — 2 dongles on different frequencies:
#  DONGLES=[{"device":0,"freq":"173.250M","gain":"40","protocols":"POCSAG1200"},{"device":1,"freq":"152.240M","gain":"35","protocols":"POCSAG512 FLEX"}]
#
#  Example — 3 dongles, all same protocol, each with its own PPM correction:
#  DONGLES=[{"device":0,"freq":"173.250M","ppm":"5"},{"device":1,"freq":"169.650M","ppm":"-3"},{"device":2,"freq":"148.000M","ppm":"0"}]
#
#  Fields per dongle (all optional, fall back to global values above):
#    device    — RTL-SDR device index (0, 1, 2...)
#    freq      — frequency (173.250M)
#    gain      — gain in dB (40)
#    ppm       — PPM correction
#    squelch   — squelch level
#    protocols — multimon-ng protocols (POCSAG1200 FLEX)
#    charset   — character encoding
# ═══════════════════════════════════════════════════════════════
# DONGLES=
